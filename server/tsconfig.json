{
  "ts-node": {
    "files": true
  },
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@books-tracker/shared": ["../packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../packages/shared/src/constants/httpStatus.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [
    {"path": "../packages/shared"}
  ]
}
